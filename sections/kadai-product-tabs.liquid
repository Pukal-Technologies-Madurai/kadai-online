
{%- liquid
  assign col_bestseller = collections[section.settings.collection_bestseller]
  assign col_latest     = collections[section.settings.collection_latest]
  assign col_featured   = collections[section.settings.collection_featured]
  assign max_p          = section.settings.max_products | default: 8
-%}

<section class="ko-product-tabs-section" id="KadaiProductTabs-{{ section.id }}">
  <div class="ko-product-tabs-inner">

    {%- comment -%} ─── SECTION HEADER ─── {%- endcomment -%}
    <div class="ko-section-header">
      <div class="ko-section-header__title-wrap">
        {%- if section.settings.section_eyebrow != blank -%}
          <p class="ko-section-header__eyebrow">{{ section.settings.section_eyebrow }}</p>
        {%- endif -%}
        <h2 class="ko-section-header__title">
          {{ section.settings.section_title | default: 'Best Seller Products' }}
        </h2>
      </div>
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="ko-section-header__link">
          {{ section.settings.view_all_label | default: 'View All' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} ─── TAB NAV ─── {%- endcomment -%}
    <div class="ko-tabs-nav" role="tablist" aria-label="Product tabs">
      <button
        class="ko-tab-pill ko-tab-pill--active"
        role="tab"
        aria-selected="true"
        aria-controls="ko-tab-panel-bestseller-{{ section.id }}"
        data-ko-product-tab="bestseller"
      >{{ section.settings.tab_bestseller | default: 'Best Seller' }}</button>
      <button
        class="ko-tab-pill"
        role="tab"
        aria-selected="false"
        aria-controls="ko-tab-panel-latest-{{ section.id }}"
        data-ko-product-tab="latest"
      >{{ section.settings.tab_latest | default: 'Latest' }}</button>
      <button
        class="ko-tab-pill"
        role="tab"
        aria-selected="false"
        aria-controls="ko-tab-panel-featured-{{ section.id }}"
        data-ko-product-tab="featured"
      >{{ section.settings.tab_featured | default: 'Featured' }}</button>
    </div>

    {%- comment -%} ─── BEST SELLER PANEL ─── {%- endcomment -%}
    <div
      class="ko-tab-panel"
      id="ko-tab-panel-bestseller-{{ section.id }}"
      role="tabpanel"
    >
      <div class="ko-product-grid">
        {%- if col_bestseller != blank and col_bestseller.products_count > 0 -%}
          {%- for product in col_bestseller.products limit: max_p -%}
            {%- liquid
              assign show_vendor = section.settings.show_vendor
              render 'ko-product-card', product: product, show_vendor: show_vendor
            -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign count = max_p -%}
          {%- render 'ko-placeholder-cards', count: count -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ─── LATEST PANEL ─── {%- endcomment -%}
    <div
      class="ko-tab-panel ko-tab-panel--hidden"
      id="ko-tab-panel-latest-{{ section.id }}"
      role="tabpanel"
    >
      <div class="ko-product-grid">
        {%- if col_latest != blank and col_latest.products_count > 0 -%}
          {%- for product in col_latest.products limit: max_p -%}
            {%- liquid
              assign show_vendor = section.settings.show_vendor
              render 'ko-product-card', product: product, show_vendor: show_vendor
            -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign count = max_p -%}
          {%- render 'ko-placeholder-cards', count: count -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ─── FEATURED PANEL ─── {%- endcomment -%}
    <div
      class="ko-tab-panel ko-tab-panel--hidden"
      id="ko-tab-panel-featured-{{ section.id }}"
      role="tabpanel"
    >
      <div class="ko-product-grid">
        {%- if col_featured != blank and col_featured.products_count > 0 -%}
          {%- for product in col_featured.products limit: max_p -%}
            {%- liquid
              assign show_vendor = section.settings.show_vendor
              render 'ko-product-card', product: product, show_vendor: show_vendor
            -%}
          {%- endfor -%}
        {%- else -%}
          {%- assign count = max_p -%}
          {%- render 'ko-placeholder-cards', count: count -%}
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

{%- comment -%}
  Inline product card and placeholder renders (snippets would be ideal
  but we inline here for self-containment)
{%- endcomment -%}

{%- for product in col_bestseller.products limit: 0 -%}{%- endfor -%}

<script>
  (function() {
    var section = document.getElementById('KadaiProductTabs-{{ section.id }}');
    if (!section) return;

    var tabBtns  = section.querySelectorAll('[data-ko-product-tab]');
    var tabPanels = section.querySelectorAll('.ko-tab-panel');

    tabBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.getAttribute('data-ko-product-tab');

        tabBtns.forEach(function(b) {
          b.classList.remove('ko-tab-pill--active');
          b.setAttribute('aria-selected', 'false');
        });
        tabPanels.forEach(function(p) { p.classList.add('ko-tab-panel--hidden'); });

        btn.classList.add('ko-tab-pill--active');
        btn.setAttribute('aria-selected', 'true');
        var panel = section.querySelector('#ko-tab-panel-' + target + '-{{ section.id }}');
        if (panel) panel.classList.remove('ko-tab-panel--hidden');
      });
    });
  })();
</script>

{% stylesheet %}
  /* ─── Product tabs section ──────────────────────── */
  .ko-product-tabs-section {
    background: #FFFFFF;
    padding: 28px 0 36px;
    border-top: 1px solid var(--ko-border, #E0E0E0);
  }

  @media screen and (min-width: 750px) {
    .ko-product-tabs-section { padding: 40px 0 52px; }
  }

  .ko-product-tabs-inner {
    padding: 0 16px;
  }

  @media screen and (min-width: 750px) {
    .ko-product-tabs-inner {
      padding: 0 24px;
      max-width: 1400px;
      margin: 0 auto;
    }
  }

  /* ─── Section header ────────────────────────────── */
  .ko-section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
    padding-bottom: 4px;
  }

  .ko-section-header__eyebrow {
    font-size: 11px;
    font-weight: 700;
    color: var(--ko-orange, #E8922A);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 6px;
  }

  .ko-section-header__title {
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    font-weight: 800;
    color: var(--ko-dark, #1A1A1A);
    line-height: 1.15;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ko-section-header__link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 700;
    color: var(--ko-orange, #E8922A);
    text-decoration: none;
    white-space: nowrap;
    padding: 6px 4px;
    transition: color 0.15s, gap 0.15s;
  }

  .ko-section-header__link:hover {
    color: var(--ko-orange-hover, #CF7E1F);
    gap: 8px;
  }

  /* ─── Tab nav ──────────────────────────────────── */
  .ko-tabs-nav {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--ko-border, #E0E0E0);
    padding-bottom: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ko-tabs-nav::-webkit-scrollbar { display: none; }

  .ko-tab-pill {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 600;
    color: var(--ko-text-gray, #666);
    background: #FFFFFF;
    border: none;
    border-radius: 8px 8px 0 0;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.18s ease;
    position: relative;
    bottom: -2px;
  }

  .ko-tab-pill--active {
    background: var(--ko-orange, #E8922A);
    color: #FFFFFF;
    border-bottom: 2px solid var(--ko-orange, #E8922A);
  }

  .ko-tab-pill:hover:not(.ko-tab-pill--active) {
    color: var(--ko-orange, #E8922A);
    background: var(--ko-orange-light, #FEF3E0);
  }

  /* ─── Tab panels ──────────────────────────────── */
  .ko-tab-panel--hidden { display: none; }

  /* ─── Product grid ─────────────────────────────── */
  .ko-product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media screen and (min-width: 550px) {
    .ko-product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 750px) {
    .ko-product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media screen and (min-width: 1100px) {
    .ko-product-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  /* ─── Product card ─────────────────────────────── */
  .ko-product-card {
    background: #FFFFFF;
    border: 1.5px solid var(--ko-border, #E0E0E0);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
  }

  .ko-product-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.10);
    transform: translateY(-2px);
  }

  .ko-product-card__wishlist {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 30px;
    height: 30px;
    background: #FFFFFF;
    border-radius: 50%;
    border: 1px solid var(--ko-border, #E0E0E0);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1;
    transition: background 0.15s, border-color 0.15s;
    color: #BBBBBB;
  }

  .ko-product-card__wishlist:hover {
    color: #E53E3E;
    border-color: #E53E3E;
  }

  .ko-product-card__img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: #FAF9F7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ko-product-card__img {
    width: 85%;
    height: 85%;
    object-fit: contain;
    transition: transform 0.28s ease;
  }

  .ko-product-card:hover .ko-product-card__img {
    transform: scale(1.05);
  }

  .ko-product-card__placeholder-icon {
    font-size: 52px;
    opacity: 0.45;
  }

  .ko-product-card__discount-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--ko-orange, #E8922A);
    color: #FFFFFF;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 9999px;
    z-index: 1;
  }

  /* Stars */
  .ko-product-card__body {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .ko-stars {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .ko-star-icon {
    font-size: 13px;
    color: var(--ko-star, #F5A623);
    line-height: 1;
  }

  .ko-star-icon--half {
    position: relative;
    display: inline-block;
  }

  .ko-star-icon--empty { color: #DDDDDD; }

  .ko-stars__count {
    font-size: 11px;
    color: var(--ko-text-muted, #999);
    margin-left: 3px;
  }

  .ko-product-card__name {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--ko-dark, #1A1A1A);
    text-decoration: none;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ko-product-card__name:hover { color: var(--ko-orange, #E8922A); }

  .ko-product-card__variant {
    font-size: 11.5px;
    color: var(--ko-text-muted, #999);
  }

  .ko-product-card__price-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 2px;
  }

  .ko-product-card__price {
    font-size: 15px;
    font-weight: 800;
    color: var(--ko-orange, #E8922A);
  }

  .ko-product-card__compare {
    font-size: 12px;
    color: var(--ko-text-muted, #999);
    text-decoration: line-through;
    font-weight: 400;
  }

  .ko-product-card__add-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    padding: 9px 12px;
    background: var(--ko-orange, #E8922A);
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 700;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    margin-top: auto;
    transition: background 0.18s, transform 0.15s;
    text-decoration: none;
  }

  .ko-product-card__add-btn:hover {
    background: var(--ko-orange-hover, #CF7E1F);
    transform: scale(1.02);
  }

  .ko-product-card__add-btn:active { transform: scale(0.98); }

  .ko-product-card__add-btn--soldout {
    background: #E0E0E0;
    color: #999;
    cursor: not-allowed;
  }

  .ko-product-card__add-btn--soldout:hover { background: #E0E0E0; transform: none; }
{% endstylesheet %}

{%- comment -%}
  We render product cards inline since snippets can't be called from sections easily
  in a self-contained way. Using {% render %} for the cards below.
{%- endcomment -%}

{% schema %}
{
  "name": "KadaiOnline Product Tabs",
  "tag": "section",
  "class": "kadai-product-tabs-wrapper section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "section_eyebrow",
      "label": "Eyebrow",
      "default": "🔥 Trending Now"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Best Seller Products"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View-all link label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View-all link URL"
    },
    {
      "type": "header",
      "content": "Tab labels"
    },
    {
      "type": "text",
      "id": "tab_bestseller",
      "label": "Tab 1 label",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "tab_latest",
      "label": "Tab 2 label",
      "default": "Latest"
    },
    {
      "type": "text",
      "id": "tab_featured",
      "label": "Tab 3 label",
      "default": "Featured"
    },
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "collection_bestseller",
      "label": "Best Seller collection"
    },
    {
      "type": "collection",
      "id": "collection_latest",
      "label": "Latest collection"
    },
    {
      "type": "collection",
      "id": "collection_featured",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products per tab",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "KadaiOnline Product Tabs",
      "settings": {
        "max_products": 8
      }
    }
  ]
}
{% endschema %}
