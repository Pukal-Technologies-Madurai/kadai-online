
<div class="ko-homepage-layout" id="KadaiHero-{{ section.id }}">

  {%- comment -%} ─── LEFT SIDEBAR (30%) — accordion on mobile, tabs on desktop ─── {%- endcomment -%}
  <aside class="ko-sidebar" aria-label="Store filters">

    {%- comment -%} ── Shop's accordion item ── {%- endcomment -%}
    <div class="ko-sidebar__item ko-sidebar__item--active" data-ko-acc="shops">
      <button
        class="ko-sidebar-tab ko-sidebar-tab--active"
        type="button"
        aria-expanded="true"
        aria-controls="ko-panel-shops-{{ section.id }}"
        data-ko-tab="shops"
      >
        <span class="ko-sidebar-tab__label">Shop's</span>
        <svg class="ko-sidebar-tab__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>
      <div class="ko-sidebar-panel" id="ko-panel-shops-{{ section.id }}" role="region" aria-label="Shops">
        {%- assign store_blocks = section.blocks | where: 'type', 'store' -%}
        {%- if store_blocks.size > 0 -%}
          {%- for block in store_blocks -%}
            {%- assign store_col = collections[block.settings.collection] -%}
            {%- assign store_url = block.settings.custom_url -%}
            {%- if store_url == blank and store_col != blank -%}
              {%- assign store_url = store_col.url -%}
            {%- elsif store_url == blank -%}
              {%- assign store_url = '/collections/all' -%}
            {%- endif -%}
            <a href="{{ store_url }}" class="ko-store-row" {{ block.shopify_attributes }}>
              <div class="ko-store-row__logo">
                {%- if block.settings.logo != blank -%}
                  {{ block.settings.logo | image_url: width: 80 | image_tag: class: 'ko-store-row__logo-img', loading: 'lazy', widths: '40, 60, 80', sizes: '40px' }}
                {%- else -%}
                  <span class="ko-store-row__logo-initial">{{ block.settings.name | default: store_col.title | upcase | slice: 0 }}</span>
                {%- endif -%}
              </div>
              <span class="ko-store-row__name">{{ block.settings.name | default: store_col.title | default: 'Store' }}</span>
              <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- assign placeholder_stores = 'Shri Foods,S|SM Traders,SM|Pukal Foods,P' | split: '|' -%}
          {%- for ps in placeholder_stores -%}
            {%- assign ps_parts = ps | split: ',' -%}
            <a href="/collections/all" class="ko-store-row">
              <div class="ko-store-row__logo">
                <span class="ko-store-row__logo-initial">{{ ps_parts[1] }}</span>
              </div>
              <span class="ko-store-row__name">{{ ps_parts[0] }}</span>
              <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Brand accordion item ── {%- endcomment -%}
    <div class="ko-sidebar__item" data-ko-acc="brands">
      <button
        class="ko-sidebar-tab"
        type="button"
        aria-expanded="false"
        aria-controls="ko-panel-brands-{{ section.id }}"
        data-ko-tab="brands"
      >
        <span class="ko-sidebar-tab__label">Brand</span>
        <svg class="ko-sidebar-tab__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>
      <div class="ko-sidebar-panel ko-sidebar-panel--hidden" id="ko-panel-brands-{{ section.id }}" role="region" aria-label="Brands">
        {%- assign brand_blocks = section.blocks | where: 'type', 'brand' -%}
        {%- for block in brand_blocks -%}
          <a href="{{ block.settings.url | default: '/collections/all' }}" class="ko-store-row" {{ block.shopify_attributes }}>
            <div class="ko-store-row__logo">
              {%- if block.settings.logo != blank -%}
                {{ block.settings.logo | image_url: width: 80 | image_tag: class: 'ko-store-row__logo-img', loading: 'lazy' }}
              {%- else -%}
                <span class="ko-store-row__logo-initial">{{ block.settings.name | upcase | slice: 0 }}</span>
              {%- endif -%}
            </div>
            <span class="ko-store-row__name">{{ block.settings.name }}</span>
            <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        {%- endfor -%}
        {%- if brand_blocks.size == 0 -%}
          <p class="ko-sidebar-empty">No brands configured.</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Category accordion item ── {%- endcomment -%}
    <div class="ko-sidebar__item" data-ko-acc="categories">
      <button
        class="ko-sidebar-tab"
        type="button"
        aria-expanded="false"
        aria-controls="ko-panel-categories-{{ section.id }}"
        data-ko-tab="categories"
      >
        <span class="ko-sidebar-tab__label">Category</span>
        <svg class="ko-sidebar-tab__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>
      <div class="ko-sidebar-panel ko-sidebar-panel--hidden" id="ko-panel-categories-{{ section.id }}" role="region" aria-label="Categories">
        {%- assign cat_blocks = section.blocks | where: 'type', 'nav_cat' -%}
        {%- for block in cat_blocks -%}
          {%- assign cat_col = collections[block.settings.collection] -%}
          {%- assign cat_url = block.settings.custom_url | default: cat_col.url | default: '/collections/all' -%}
          <a href="{{ cat_url }}" class="ko-store-row" {{ block.shopify_attributes }}>
            <div class="ko-store-row__logo ko-store-row__logo--emoji">
              <span aria-hidden="true">{{ block.settings.emoji | default: '🛒' }}</span>
            </div>
            <span class="ko-store-row__name">{{ block.settings.label | default: cat_col.title | default: 'Category' }}</span>
            <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        {%- endfor -%}
        {%- if cat_blocks.size == 0 -%}
          <p class="ko-sidebar-empty">No categories configured.</p>
        {%- endif -%}
      </div>
    </div>

  </aside>

  {%- comment -%} ─── HERO IMAGE SLIDER (70%) ─────────────────────────── {%- endcomment -%}
  {%- assign slide_blocks = section.blocks | where: 'type', 'hero_slide' -%}
  <div class="ko-hero-slider" data-ko-slider role="region" aria-roledescription="carousel" aria-label="Hero promotions">
    <div class="ko-hero-slider__track" data-ko-slider-track>

      {%- if slide_blocks.size > 0 -%}
        {%- for block in slide_blocks -%}
          <div class="ko-hero-slide" data-ko-slide role="group" aria-roledescription="slide" aria-label="Slide {{ forloop.index }} of {{ slide_blocks.size }}" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="ko-hero-slide__link" aria-label="{{ block.settings.headline | default: 'Promotion' }}">{%- endif -%}
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  class: 'ko-hero-slide__img',
                  loading: forloop.first | if: 'eager', else: 'lazy',
                  fetchpriority: forloop.first | if: 'high', else: 'auto',
                  widths: '600, 900, 1200, 1600',
                  sizes: '(min-width: 750px) 70vw, 100vw'
              }}
            {%- else -%}
              <div class="ko-hero-gradient ko-hero-gradient--{{ forloop.index0 | modulo: 3 }}">
                <div class="ko-hero-text">
                  {%- if block.settings.eyebrow != blank -%}<p class="ko-hero-eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
                  <h2 class="ko-hero-headline">{{ block.settings.headline | default: 'Special Offer' }}</h2>
                  {%- if block.settings.subheadline != blank -%}<p class="ko-hero-sub">{{ block.settings.subheadline }}</p>{%- endif -%}
                  {%- if block.settings.body != blank -%}<p class="ko-hero-body">{{ block.settings.body }}</p>{%- endif -%}
                  {%- if block.settings.cta_label != blank -%}
                    <span class="ko-hero-cta">{{ block.settings.cta_label }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback: single hero from section settings (legacy) {%- endcomment -%}
        <div class="ko-hero-slide" data-ko-slide>
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 1600
              | image_tag:
                class: 'ko-hero-slide__img',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '600, 900, 1200, 1600',
                sizes: '(min-width: 750px) 70vw, 100vw'
            }}
          {%- else -%}
            <div class="ko-hero-gradient">
              <div class="ko-hero-text">
                {%- if section.settings.eyebrow != blank -%}<p class="ko-hero-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
                <h1 class="ko-hero-headline">{{ section.settings.headline | default: 'SUNLIT HARVEST GRAINS' }}</h1>
                <p class="ko-hero-sub">{{ section.settings.subheadline | default: 'NOURISHING EVERY MEAL' }}</p>
                <p class="ko-hero-body">{{ section.settings.body | default: 'Experience the pure, healthy, organic whole grains, lentils, and pulses, sun-grown and delivered fresh to your kitchen.' }}</p>
                <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="ko-hero-cta">
                  {{ section.settings.cta_label | default: 'SHOP NOW' }}
                </a>
              </div>
              <div class="ko-hero-decoration" aria-hidden="true">
                <span class="ko-hero-grain">🌾</span>
                <span class="ko-hero-grain ko-hero-grain--2">🫘</span>
                <span class="ko-hero-grain ko-hero-grain--3">🌶️</span>
              </div>
            </div>
          {%- endif -%}
        </div>
        {%- comment -%} Add 2 placeholder gradient slides so slider behavior is visible {%- endcomment -%}
        <div class="ko-hero-slide" data-ko-slide>
          <div class="ko-hero-gradient ko-hero-gradient--1">
            <div class="ko-hero-text">
              <p class="ko-hero-eyebrow">🌶️ Hot Deals</p>
              <h2 class="ko-hero-headline">SPICE UP YOUR<br>KITCHEN</h2>
              <p class="ko-hero-sub">UP TO 30% OFF</p>
              <p class="ko-hero-body">Authentic Tamil spices freshly ground and packed for your daily cooking needs.</p>
              <a href="/collections/all" class="ko-hero-cta">SHOP SPICES</a>
            </div>
          </div>
        </div>
        <div class="ko-hero-slide" data-ko-slide>
          <div class="ko-hero-gradient ko-hero-gradient--2">
            <div class="ko-hero-text">
              <p class="ko-hero-eyebrow">🥛 Daily Essentials</p>
              <h2 class="ko-hero-headline">FRESH FROM<br>THE FARM</h2>
              <p class="ko-hero-sub">FREE DELIVERY ABOVE ₹499</p>
              <p class="ko-hero-body">Pure dairy products and farm-fresh items delivered straight to your door.</p>
              <a href="/collections/all" class="ko-hero-cta">SHOP NOW</a>
            </div>
          </div>
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Slider controls {%- endcomment -%}
    <button class="ko-slider-nav ko-slider-nav--prev" data-ko-slider-prev type="button" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button class="ko-slider-nav ko-slider-nav--next" data-ko-slider-next type="button" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <div class="ko-slider-dots" data-ko-slider-dots role="tablist" aria-label="Slide navigation"></div>
  </div>

</div>

{%- comment -%} Sidebar tab + slider JS {%- endcomment -%}
<script>
  (function() {
    var container = document.getElementById('KadaiHero-{{ section.id }}');
    if (!container) return;

    /* ── Sidebar accordion / tab switching ── */
    var items = container.querySelectorAll('[data-ko-acc]');
    var tabs  = container.querySelectorAll('[data-ko-tab]');
    var panels = container.querySelectorAll('.ko-sidebar-panel');

    function activate(key) {
      items.forEach(function(it) {
        var match = it.getAttribute('data-ko-acc') === key;
        it.classList.toggle('ko-sidebar__item--active', match);
        var t = it.querySelector('[data-ko-tab]');
        var p = it.querySelector('.ko-sidebar-panel');
        if (t) {
          t.classList.toggle('ko-sidebar-tab--active', match);
          t.setAttribute('aria-expanded', match ? 'true' : 'false');
        }
        if (p) p.classList.toggle('ko-sidebar-panel--hidden', !match);
      });
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var key = tab.getAttribute('data-ko-tab');
        var item = tab.closest('[data-ko-acc]');
        var isOpen = item && item.classList.contains('ko-sidebar__item--active');
        var isMobile = window.matchMedia('(max-width: 749px)').matches;
        // On mobile, allow tap-to-collapse the active one. On desktop, keep one always open.
        if (isMobile && isOpen) {
          item.classList.remove('ko-sidebar__item--active');
          tab.classList.remove('ko-sidebar-tab--active');
          tab.setAttribute('aria-expanded', 'false');
          var p = item.querySelector('.ko-sidebar-panel');
          if (p) p.classList.add('ko-sidebar-panel--hidden');
        } else {
          activate(key);
        }
      });
    });

    /* ── Image slider ── */
    var slider = container.querySelector('[data-ko-slider]');
    if (!slider) return;
    var track = slider.querySelector('[data-ko-slider-track]');
    var slides = slider.querySelectorAll('[data-ko-slide]');
    var prevBtn = slider.querySelector('[data-ko-slider-prev]');
    var nextBtn = slider.querySelector('[data-ko-slider-next]');
    var dotsWrap = slider.querySelector('[data-ko-slider-dots]');
    if (slides.length === 0) return;
    var idx = 0;
    var autoplayMs = 5000;
    var timer = null;

    function buildDots() {
      dotsWrap.innerHTML = '';
      for (var i = 0; i < slides.length; i++) {
        var btn = document.createElement('button');
        btn.className = 'ko-slider-dot';
        btn.setAttribute('type', 'button');
        btn.setAttribute('role', 'tab');
        btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        btn.dataset.idx = i;
        if (i === 0) btn.classList.add('ko-slider-dot--active');
        btn.addEventListener('click', function(e) {
          go(parseInt(e.currentTarget.dataset.idx, 10));
          restart();
        });
        dotsWrap.appendChild(btn);
      }
    }

    function go(n) {
      idx = (n + slides.length) % slides.length;
      track.style.transform = 'translateX(' + (-idx * 100) + '%)';
      var dots = dotsWrap.querySelectorAll('.ko-slider-dot');
      dots.forEach(function(d, i) { d.classList.toggle('ko-slider-dot--active', i === idx); });
    }
    function next() { go(idx + 1); }
    function prev() { go(idx - 1); }
    function restart() {
      if (timer) clearInterval(timer);
      if (slides.length > 1) timer = setInterval(next, autoplayMs);
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); restart(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { next(); restart(); });

    /* Touch swipe */
    var startX = null;
    track.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', function(e) {
      if (startX === null) return;
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 40) { dx < 0 ? next() : prev(); restart(); }
      startX = null;
    }, { passive: true });

    /* Hide controls if only one slide */
    if (slides.length <= 1) {
      if (prevBtn) prevBtn.style.display = 'none';
      if (nextBtn) nextBtn.style.display = 'none';
    }

    buildDots();
    restart();
  })();
</script>

{% stylesheet %}
  :root {
    --ko-orange: #E8922A;
    --ko-orange-hover: #CF7E1F;
    --ko-orange-light: #FEF3E0;
    --ko-star: #F5A623;
    --ko-dark: #1A1A1A;
    --ko-text: #333333;
    --ko-text-gray: #666666;
    --ko-text-muted: #999999;
    --ko-bg: #F5F5F5;
    --ko-card-bg: #FFFFFF;
    --ko-border: #E0E0E0;
  }

  /* ─── HOMEPAGE LAYOUT GRID (30/70) ──────────────── */
  .ko-homepage-layout {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    min-height: 360px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 12px;
    gap: 12px;
  }

  @media screen and (min-width: 750px) {
    .ko-homepage-layout {
      display: grid;
      grid-template-columns: 30% 70%;
      gap: 16px;
      padding: 16px;
      min-height: 460px;
    }
  }

  @media screen and (min-width: 990px) {
    .ko-homepage-layout {
      padding: 20px;
      gap: 20px;
    }
  }

  /* ─── SIDEBAR (30%) — accordion (mobile), tabs+panel (desktop) ─── */
  .ko-sidebar {
    display: flex;
    flex-direction: column;
    background: #FFFFFF;
    border: 1px solid var(--ko-border);
    border-radius: 14px;
    overflow: hidden;
    min-height: 0;
  }

  /* — Accordion item wrapper (mobile default) — */
  .ko-sidebar__item {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--ko-border);
  }

  .ko-sidebar__item:last-child { border-bottom: none; }

  /* — Tab/accordion header button — */
  .ko-sidebar-tab {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    width: 100%;
    padding: 14px 16px;
    font-size: 14px;
    font-weight: 700;
    color: var(--ko-text);
    background: #FAFAFA;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
    white-space: nowrap;
    text-align: left;
    line-height: 1;
  }

  .ko-sidebar-tab:hover { background: var(--ko-orange-light); color: var(--ko-orange); }

  .ko-sidebar-tab--active {
    background: var(--ko-orange);
    color: #FFFFFF;
  }

  .ko-sidebar-tab--active:hover { background: var(--ko-orange-hover); color: #FFFFFF; }

  .ko-sidebar-tab__chevron {
    transition: transform 0.22s ease;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .ko-sidebar-tab--active .ko-sidebar-tab__chevron {
    transform: rotate(180deg);
    opacity: 1;
  }

  /* — Panel (mobile: collapsible under each tab) — */
  .ko-sidebar-panel {
    overflow-y: auto;
    padding: 4px 0;
    max-height: 320px;
    background: #FFFFFF;
    border-top: 1px solid #F0F0F0;
  }

  .ko-sidebar-panel--hidden { display: none; }

  .ko-sidebar-empty {
    padding: 24px 16px;
    color: var(--ko-text-muted);
    font-size: 13px;
    text-align: center;
  }

  /* — Desktop: tabs in a row, single panel below — */
  @media screen and (min-width: 750px) {
    .ko-sidebar {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: auto 1fr;
      grid-auto-flow: dense;
    }
    .ko-sidebar__item {
      display: contents;
      border-bottom: none;
    }
    .ko-sidebar-tab {
      grid-row: 1;
      padding: 11px 8px;
      font-size: 13px;
      justify-content: center;
      background: #FAFAFA;
      border-bottom: 1px solid var(--ko-border);
      border-right: 1px solid var(--ko-border);
    }
    .ko-sidebar__item:last-child .ko-sidebar-tab { border-right: none; }
    .ko-sidebar-tab__chevron { display: none; }
    .ko-sidebar-tab--active {
      background: var(--ko-orange);
      color: #FFFFFF;
      box-shadow: 0 2px 6px rgba(232, 146, 42, 0.3);
    }
    .ko-sidebar-panel {
      grid-row: 2;
      grid-column: 1 / -1;
      max-height: none;
      border-top: none;
    }
  }

  /* Store row */
  .ko-store-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    text-decoration: none;
    border-bottom: 1px solid #F4F4F4;
    transition: background 0.15s;
    cursor: pointer;
  }

  .ko-store-row:last-child { border-bottom: none; }

  .ko-store-row:hover { background: #FFF8F0; }

  .ko-store-row:hover .ko-store-row__arrow {
    color: var(--ko-orange);
    transform: translateX(2px);
  }

  .ko-store-row__logo {
    width: 40px; height: 40px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--ko-orange-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ko-border);
  }

  .ko-store-row__logo--emoji { font-size: 20px; background: #FFF3E0; }
  .ko-store-row__logo-img { width: 100%; height: 100%; object-fit: contain; }

  .ko-store-row__logo-initial {
    font-size: 14px;
    font-weight: 800;
    color: var(--ko-orange);
    text-transform: uppercase;
  }

  .ko-store-row__name {
    flex: 1;
    font-size: 14px;
    font-weight: 600;
    color: var(--ko-text);
    line-height: 1.3;
  }

  .ko-store-row__arrow {
    color: #BBBBBB;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  /* ─── HERO IMAGE SLIDER (70%) ────────────────────── */
  .ko-hero-slider {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    background: var(--ko-orange-light);
    min-height: 280px;
    display: flex;
  }

  @media screen and (min-width: 750px) {
    .ko-hero-slider { min-height: 460px; }
  }

  .ko-hero-slider__track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.55s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .ko-hero-slide {
    flex: 0 0 100%;
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: stretch;
    overflow: hidden;
  }

  .ko-hero-slide__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ko-hero-slide__img {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .ko-hero-slide__img { min-height: 460px; }
  }

  /* Gradient slide variants */
  .ko-hero-gradient {
    width: 100%;
    background: linear-gradient(135deg, #C47B1A 0%, #D48A1E 25%, #E8A030 50%, #F0B840 70%, #F5C855 100%);
    display: flex;
    align-items: center;
    padding: 28px 24px;
    gap: 24px;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .ko-hero-gradient { padding: 48px 56px; }
  }

  .ko-hero-gradient--1 {
    background: linear-gradient(135deg, #B8451C 0%, #D1612A 35%, #E87B3A 70%, #F19858 100%);
  }
  .ko-hero-gradient--2 {
    background: linear-gradient(135deg, #2D5F3F 0%, #4A8259 35%, #6BA37A 70%, #8DC09B 100%);
  }

  .ko-hero-gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Ccircle cx='50' cy='50' r='40'/%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .ko-hero-text {
    flex: 1;
    z-index: 1;
    max-width: 460px;
    color: #2D1600;
  }

  .ko-hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.92);
    margin: 0 0 10px;
  }

  .ko-hero-headline {
    font-size: clamp(1.5rem, 4vw, 2.6rem);
    font-weight: 900;
    color: #2D1600;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .ko-hero-sub {
    font-size: clamp(0.85rem, 2vw, 1rem);
    font-weight: 700;
    color: #3D2008;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .ko-hero-body {
    font-size: 13px;
    color: rgba(60, 30, 5, 0.85);
    line-height: 1.6;
    margin: 0 0 22px;
    max-width: 320px;
  }

  @media screen and (min-width: 750px) { .ko-hero-body { font-size: 14px; } }

  .ko-hero-cta {
    display: inline-flex;
    align-items: center;
    background: #3D2208;
    color: #FFFFFF !important;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 12px 26px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.18s, transform 0.15s;
  }

  .ko-hero-cta:hover { background: #2A1605; transform: translateY(-1px); }

  .ko-hero-decoration { display: none; }
  @media screen and (min-width: 990px) {
    .ko-hero-decoration {
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 1;
    }
  }

  .ko-hero-grain {
    font-size: 56px;
    animation: ko-float 3s ease-in-out infinite;
    display: block;
  }

  .ko-hero-grain--2 { animation-delay: 0.8s; font-size: 48px; }
  .ko-hero-grain--3 { animation-delay: 1.6s; font-size: 40px; }

  @keyframes ko-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ─── SLIDER NAV (arrows) ─────────────────────────── */
  .ko-slider-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 38px; height: 38px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.92);
    color: var(--ko-dark);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    transition: background 0.15s, transform 0.15s;
    z-index: 4;
    opacity: 0;
  }

  .ko-hero-slider:hover .ko-slider-nav,
  .ko-hero-slider:focus-within .ko-slider-nav { opacity: 1; }

  @media (hover: none) {
    .ko-slider-nav { opacity: 1; width: 34px; height: 34px; }
  }

  .ko-slider-nav:hover {
    background: #FFFFFF;
    color: var(--ko-orange);
    transform: translateY(-50%) scale(1.05);
  }

  .ko-slider-nav--prev { left: 12px; }
  .ko-slider-nav--next { right: 12px; }

  /* ─── SLIDER DOTS ──────────────────────────────── */
  .ko-slider-dots {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 4;
  }

  .ko-slider-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.55);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: width 0.25s, background 0.2s;
  }

  .ko-slider-dot--active {
    background: #FFFFFF;
    width: 24px;
    border-radius: 4px;
  }
{% endstylesheet %}

