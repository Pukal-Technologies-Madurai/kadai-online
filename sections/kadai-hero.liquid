
<div class="ko-homepage-layout" id="KadaiHero-{{ section.id }}">

  {%- comment -%} ─── LEFT SIDEBAR ─────────────────────────────────── {%- endcomment -%}
  <aside class="ko-sidebar" aria-label="Store filters">

    <div class="ko-sidebar__tab-nav" role="tablist">
      <button class="ko-sidebar-tab ko-sidebar-tab--active" role="tab" aria-selected="true"  data-ko-tab="shops"      aria-controls="ko-panel-shops">Shop's</button>
      <button class="ko-sidebar-tab"                         role="tab" aria-selected="false" data-ko-tab="brands"     aria-controls="ko-panel-brands">Brand</button>
      <button class="ko-sidebar-tab"                         role="tab" aria-selected="false" data-ko-tab="categories" aria-controls="ko-panel-categories">Category</button>
    </div>

    {%- comment -%} Shop's panel {%- endcomment -%}
    <div class="ko-sidebar-panel" id="ko-panel-shops" role="tabpanel">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'store' -%}
            {%- assign store_col = collections[block.settings.collection] -%}
            {%- assign store_url = block.settings.custom_url -%}
            {%- if store_url == blank and store_col != blank -%}
              {%- assign store_url = store_col.url -%}
            {%- elsif store_url == blank -%}
              {%- assign store_url = '/collections/all' -%}
            {%- endif -%}
            <a href="{{ store_url }}" class="ko-store-row" {{ block.shopify_attributes }}>
              <div class="ko-store-row__logo">
                {%- if block.settings.logo != blank -%}
                  {{
                    block.settings.logo
                    | image_url: width: 80
                    | image_tag:
                      class: 'ko-store-row__logo-img',
                      loading: 'lazy',
                      widths: '40, 60, 80',
                      sizes: '40px'
                  }}
                {%- else -%}
                  <span class="ko-store-row__logo-initial">{{ block.settings.name | default: store_col.title | upcase | slice: 0 }}</span>
                {%- endif -%}
              </div>
              <span class="ko-store-row__name">{{ block.settings.name | default: store_col.title | default: 'Store' }}</span>
              <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Placeholder stores {%- endcomment -%}
        {%- assign placeholder_stores = 'Shri Foods,S|SM Traders,SM|Pukal Foods,P' | split: '|' -%}
        {%- for ps in placeholder_stores -%}
          {%- assign ps_parts = ps | split: ',' -%}
          <a href="/collections/all" class="ko-store-row">
            <div class="ko-store-row__logo">
              <span class="ko-store-row__logo-initial">{{ ps_parts[1] }}</span>
            </div>
            <span class="ko-store-row__name">{{ ps_parts[0] }}</span>
            <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Brand panel {%- endcomment -%}
    <div class="ko-sidebar-panel ko-sidebar-panel--hidden" id="ko-panel-brands" role="tabpanel">
      {%- for block in section.blocks -%}
        {%- if block.type == 'brand' -%}
          <a href="{{ block.settings.url | default: '/collections/all' }}" class="ko-store-row" {{ block.shopify_attributes }}>
            <div class="ko-store-row__logo">
              {%- if block.settings.logo != blank -%}
                {{ block.settings.logo | image_url: width: 80 | image_tag: class: 'ko-store-row__logo-img', loading: 'lazy' }}
              {%- else -%}
                <span class="ko-store-row__logo-initial">{{ block.settings.name | upcase | slice: 0 }}</span>
              {%- endif -%}
            </div>
            <span class="ko-store-row__name">{{ block.settings.name }}</span>
            <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
      {%- assign brand_blocks = section.blocks | where: 'type', 'brand' -%}
      {%- if brand_blocks.size == 0 -%}
        <p class="ko-sidebar-empty">No brands configured.</p>
      {%- endif -%}
    </div>

    {%- comment -%} Category panel {%- endcomment -%}
    <div class="ko-sidebar-panel ko-sidebar-panel--hidden" id="ko-panel-categories" role="tabpanel">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_cat' -%}
          {%- assign cat_col = collections[block.settings.collection] -%}
          {%- assign cat_url = block.settings.custom_url | default: cat_col.url | default: '/collections/all' -%}
          <a href="{{ cat_url }}" class="ko-store-row" {{ block.shopify_attributes }}>
            <div class="ko-store-row__logo ko-store-row__logo--emoji">
              <span aria-hidden="true">{{ block.settings.emoji | default: '🛒' }}</span>
            </div>
            <span class="ko-store-row__name">{{ block.settings.label | default: cat_col.title | default: 'Category' }}</span>
            <svg class="ko-store-row__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        {%- endif -%}
      {%- endfor -%}
      {%- assign cat_blocks = section.blocks | where: 'type', 'nav_cat' -%}
      {%- if cat_blocks.size == 0 -%}
        <p class="ko-sidebar-empty">No categories configured.</p>
      {%- endif -%}
    </div>

  </aside>

  {%- comment -%} ─── HERO BANNER ──────────────────────────────────── {%- endcomment -%}
  <div class="ko-hero-banner">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 1200
        | image_tag:
          class: 'ko-hero-banner__img',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '600, 900, 1100, 1200',
          sizes: '(min-width: 750px) 72vw, 100vw'
      }}
    {%- else -%}
      {%- comment -%} Gradient fallback with text content {%- endcomment -%}
      <div class="ko-hero-gradient">
        <div class="ko-hero-text">
          {%- if section.settings.eyebrow != blank -%}
            <p class="ko-hero-eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h1 class="ko-hero-headline">{{ section.settings.headline | default: 'SUNLIT HARVEST GRAINS' }}</h1>
          <p class="ko-hero-sub">{{ section.settings.subheadline | default: 'NOURISHING EVERY MEAL' }}</p>
          <p class="ko-hero-body">{{ section.settings.body | default: 'Experience the pure, healthy, organic whole grains, lentils, and pulses, sun-grown and delivered fresh to your kitchen.' }}</p>
          <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="ko-hero-cta">
            {{ section.settings.cta_label | default: 'SHOP NOW' }}
          </a>
        </div>
        <div class="ko-hero-decoration" aria-hidden="true">
          <span class="ko-hero-grain">🌾</span>
          <span class="ko-hero-grain ko-hero-grain--2">🫘</span>
          <span class="ko-hero-grain ko-hero-grain--3">🌶️</span>
        </div>
      </div>
    {%- endif -%}
  </div>

</div>

{%- comment -%} Sidebar tab JS {%- endcomment -%}
<script>
  (function() {
    var container = document.getElementById('KadaiHero-{{ section.id }}');
    if (!container) return;
    var tabs = container.querySelectorAll('[data-ko-tab]');
    var panels = container.querySelectorAll('.ko-sidebar-panel');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = tab.getAttribute('data-ko-tab');
        tabs.forEach(function(t) { t.classList.remove('ko-sidebar-tab--active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(function(p) { p.classList.add('ko-sidebar-panel--hidden'); });
        tab.classList.add('ko-sidebar-tab--active');
        tab.setAttribute('aria-selected', 'true');
        var panel = container.querySelector('#ko-panel-' + target);
        if (panel) panel.classList.remove('ko-sidebar-panel--hidden');
      });
    });
  })();
</script>

{% stylesheet %}
  :root {
    --ko-orange: #E8922A;
    --ko-orange-hover: #CF7E1F;
    --ko-orange-light: #FEF3E0;
    --ko-star: #F5A623;
    --ko-dark: #1A1A1A;
    --ko-text: #333333;
    --ko-text-gray: #666666;
    --ko-text-muted: #999999;
    --ko-bg: #F5F5F5;
    --ko-card-bg: #FFFFFF;
    --ko-border: #E0E0E0;
  }

  /* ─── HOMEPAGE LAYOUT GRID ──────────────────────── */
  .ko-homepage-layout {
    display: flex;
    background: #FFFFFF;
    min-height: 400px;
  }

  @media screen and (min-width: 750px) {
    .ko-homepage-layout {
      display: grid;
      grid-template-columns: 300px 1fr;
    }
  }

  /* ─── SIDEBAR ──────────────────────────────────── */
  .ko-sidebar {
    display: none;
    flex-direction: column;
    background: #FFFFFF;
    border-right: 1px solid var(--ko-border);
    min-height: 420px;
  }

  @media screen and (min-width: 750px) {
    .ko-sidebar {
      display: flex;
    }
  }

  /* Tab nav */
  .ko-sidebar__tab-nav {
    display: flex;
    gap: 0;
    padding: 16px 16px 0;
    border-bottom: 1px solid var(--ko-border);
  }

  .ko-sidebar-tab {
    flex: 1;
    padding: 10px 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ko-text-gray);
    background: none;
    border: none;
    border-radius: 9999px 9999px 0 0;
    cursor: pointer;
    transition: all 0.18s ease;
    white-space: nowrap;
  }

  .ko-sidebar-tab--active {
    background: var(--ko-orange);
    color: #FFFFFF;
    border-radius: 9999px;
    margin-bottom: -1px;
    padding-bottom: 11px;
  }

  .ko-sidebar-tab:hover:not(.ko-sidebar-tab--active) {
    color: var(--ko-orange);
  }

  /* Sidebar panels */
  .ko-sidebar-panel {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }

  .ko-sidebar-panel--hidden {
    display: none;
  }

  .ko-sidebar-empty {
    padding: 24px 16px;
    color: var(--ko-text-muted);
    font-size: 13px;
    text-align: center;
  }

  /* Store row */
  .ko-store-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    text-decoration: none;
    border-bottom: 1px solid #F0F0F0;
    transition: background 0.15s;
    cursor: pointer;
  }

  .ko-store-row:last-child {
    border-bottom: none;
  }

  .ko-store-row:hover {
    background: #FFF8F0;
  }

  .ko-store-row:hover .ko-store-row__arrow {
    color: var(--ko-orange);
    transform: translateX(2px);
  }

  .ko-store-row__logo {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--ko-orange-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ko-border);
  }

  .ko-store-row__logo--emoji {
    font-size: 22px;
    background: #FFF3E0;
  }

  .ko-store-row__logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ko-store-row__logo-initial {
    font-size: 14px;
    font-weight: 800;
    color: var(--ko-orange);
    text-transform: uppercase;
  }

  .ko-store-row__name {
    flex: 1;
    font-size: 14px;
    font-weight: 600;
    color: var(--ko-text);
    line-height: 1.3;
  }

  .ko-store-row__arrow {
    color: #BBBBBB;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  /* ─── HERO BANNER ──────────────────────────────── */
  .ko-hero-banner {
    position: relative;
    overflow: hidden;
    min-height: 380px;
    display: flex;
    align-items: stretch;
  }

  @media screen and (min-width: 750px) {
    .ko-hero-banner {
      min-height: 420px;
    }
  }

  .ko-hero-banner__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Gradient fallback */
  .ko-hero-gradient {
    width: 100%;
    background: linear-gradient(135deg,
      #C47B1A 0%,
      #D48A1E 25%,
      #E8A030 50%,
      #F0B840 70%,
      #F5C855 100%
    );
    display: flex;
    align-items: center;
    padding: 40px 36px;
    gap: 24px;
    position: relative;
    overflow: hidden;
  }

  .ko-hero-gradient::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='50' cy='50' r='40'/%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .ko-hero-text {
    flex: 1;
    z-index: 1;
    max-width: 340px;
  }

  .ko-hero-eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin: 0 0 10px;
  }

  .ko-hero-headline {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 900;
    color: #2D1600;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
    text-transform: uppercase;
  }

  .ko-hero-sub {
    font-size: clamp(0.85rem, 2vw, 1rem);
    font-weight: 700;
    color: #3D2008;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 16px;
  }

  .ko-hero-body {
    font-size: 14px;
    color: rgba(60, 30, 5, 0.80);
    line-height: 1.65;
    margin: 0 0 28px;
    max-width: 280px;
  }

  .ko-hero-cta {
    display: inline-flex;
    align-items: center;
    background: #3D2208;
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 13px 30px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.18s, transform 0.15s;
  }

  .ko-hero-cta:hover {
    background: #2A1605;
    transform: translateY(-1px);
  }

  .ko-hero-decoration {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .ko-hero-decoration {
      display: flex;
      flex-direction: column;
      gap: 8px;
      z-index: 1;
    }
  }

  .ko-hero-grain {
    font-size: 56px;
    animation: ko-float 3s ease-in-out infinite;
    display: block;
  }

  .ko-hero-grain--2 { animation-delay: 0.8s; font-size: 48px; }
  .ko-hero-grain--3 { animation-delay: 1.6s; font-size: 40px; }

  @keyframes ko-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
{% endstylesheet %}

